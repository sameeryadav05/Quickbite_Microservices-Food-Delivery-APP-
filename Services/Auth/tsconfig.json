{
  "compilerOptions": {

    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2020",
    // For nodejs:
    "lib": ["ES2020"],
    "types": ["node"],
// npm install -D @types/node

    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,


    // Recommended Options
    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  }
}
